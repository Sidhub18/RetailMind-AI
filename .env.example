# Copy this file to .env for local development.
# Never place real credentials or secret values in this example file.

# Container build
PYTHON_IMAGE=python:3.12.13-slim-bookworm
IMAGE_NAME=retailmind-ai-workspace
IMAGE_TAG=local
APP_UID=10001
APP_GID=10001
CONTAINER_CPU_LIMIT=4.0
CONTAINER_MEMORY_LIMIT=8g

# Application environment
RETAILMIND_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
TZ=UTC
PYTHONPATH=/workspace/src

# Local project paths
CONFIG_ROOT=/workspace/config
DATA_ROOT=/workspace/data
MODEL_ROOT=/workspace/models
PROMPT_ROOT=/workspace/prompts
REPORT_ROOT=/workspace/reports

# AWS workload identity
# Prefer AWS SSO or temporary role credentials. Do not store access keys here.
AWS_REGION=
AWS_PROFILE=
AWS_ENDPOINT_URL=

# Transactional persistence
DATABASE_URL=

# OpenTelemetry
OTEL_SERVICE_NAME=retailmind-ai
OTEL_EXPORTER_OTLP_ENDPOINT=

# Enterprise integrations
ERP_BASE_URL=
ERP_SECRET_ARN=
